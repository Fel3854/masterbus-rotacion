# ============================================
# Variables de entorno globales
# Copia este archivo como .env y completa los valores
# ============================================

# Base de datos
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# APIs externas
# API_KEY=tu-clave-aqui
MASTERBUS_API_URL=https://traficonuevo.masterbus.net/api/v1/auto/e

# SMTP — Servidor de correo corporativo
SMTP_HOST=smtp.tu-servidor.com
SMTP_PORT=587
SMTP_USER=usuario@empresa.com
SMTP_PASSWORD=tu-contraseña-aqui
SMTP_USE_TLS=true

# RRHH — Destinatario de alertas
RRHH_EMAIL=rrhh@empresa.com

# Alerta Período de Prueba — Rango de días para "mes 5"
ALERTA_DIA_MIN=150
ALERTA_DIA_MAX=180

# Configuración general
DEBUG=false
LOG_LEVEL=INFO
